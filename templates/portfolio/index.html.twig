{% extends 'base.html.twig' %}

{% block title %}Portfolio | FinApp{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .portfolio-exposure-chart {
            aspect-ratio: 1;
            height: min(100vw - 80px, 320px);
            max-height: 320px;
            max-width: 320px;
            position: relative;
            width: 100%;
        }

        .portfolio-exposure-legend {
            column-gap: 1.5rem;
            display: grid;
            grid-auto-flow: column;
            grid-template-rows: repeat(5, auto);
            justify-content: start;
            min-width: max-content;
            row-gap: .75rem;
        }

        .portfolio-exposure-legend-scroll {
            max-width: 100%;
            overflow-x: auto;
            padding-bottom: .5rem;
        }

        .portfolio-exposure-item {
            align-items: center;
            display: grid;
            column-gap: .45rem;
            grid-template-columns: 14px max-content max-content;
            max-width: 100%;
        }

        .portfolio-exposure-swatch {
            border-radius: 999px;
            height: 14px;
            width: 14px;
        }

        @media (max-width: 575.98px) {
            .portfolio-exposure-legend {
                grid-auto-flow: row;
                grid-template-rows: none;
            }
        }
    </style>
{% endblock %}

{% block main %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
        <div>
            <div class="page-kicker">{{ selectedBrokerAccount ? 'Filtered by broker account' : 'Aggregated across broker accounts' }}</div>
            <h1 class="h2 mb-0">Portfolio</h1>
            {% if selectedBrokerAccount %}
                <div class="text-secondary mt-1">{{ selectedBrokerAccount.displayName }}</div>
            {% endif %}
        </div>
        <a class="btn btn-dark" href="{{ path('app_transaction_upload') }}">Upload transactions</a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" action="{{ path('app_portfolio') }}" class="row g-3 align-items-end">
                <div class="col-md-5 col-lg-4">
                    <label for="bid" class="form-label">Broker account</label>
                    <select id="bid" name="bid" class="form-select">
                        <option value="">All broker accounts</option>
                        {% for account in brokerAccounts %}
                            <option value="{{ account.id }}" {{ selectedBrokerAccountId == account.id ? 'selected' }}>
                                {{ account.displayName }} · {{ account.brokerTypeLabel }} · {{ account.currency }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-auto">
                    <button class="btn btn-dark" type="submit">Apply</button>
                    {% if selectedBrokerAccount %}
                        <a class="btn btn-outline-secondary ms-2" href="{{ path('app_portfolio') }}">Clear</a>
                    {% endif %}
                </div>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <div class="text-secondary mb-2">Market Value</div>
                    <div class="h3 mb-0">{{ totals.marketValue is not null ? totals.marketValue|money_symbol('USD') : 'Unavailable' }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <div class="text-secondary mb-2">Realized P/L</div>
                    <div class="h3 mb-0 {{ totals.realizedGain starts with '-' ? 'text-negative' : 'text-positive' }}">
                        {{ totals.realizedGain|money_symbol('USD') }}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <div class="text-secondary mb-2">Unrealized P/L</div>
                    {% if totals.unrealizedGain is not null %}
                        <div class="h3 mb-0 {{ totals.unrealizedGain starts with '-' ? 'text-negative' : 'text-positive' }}">
                            {{ totals.unrealizedGain|money_symbol('USD') }}
                        </div>
                    {% else %}
                        <div class="h3 mb-0">Unavailable</div>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <div class="text-secondary mb-2">Total P/L</div>
                    {% if totals.totalGain is not null %}
                        <div class="h3 mb-0 {{ totals.totalGain starts with '-' ? 'text-negative' : 'text-positive' }}">
                            {{ totals.totalGain|money_symbol('USD') }}
                        </div>
                    {% else %}
                        <div class="h3 mb-0">Unavailable</div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {% if not marketDataAvailable %}
        <div class="alert alert-warning">
            {% if partialMarketData %}
                Some market data is unavailable. Portfolio metrics exclude stocks without current prices.
            {% else %}
                Market data is unavailable at this moment.
            {% endif %}
            {% if unavailableSymbols is not empty %}
                <div class="mt-2 d-flex flex-wrap gap-2">
                    {% for symbol in unavailableSymbols %}
                        <span class="badge text-bg-light border">{{ symbol }}</span>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    {% endif %}

    <div class="card mb-4">
        <div class="card-body">
            <div class="mb-3">
                <h2 class="h5 mb-1">Exposure</h2>
                <div class="text-secondary">Based on current market value by stock{{ selectedBrokerAccount ? ' in ' ~ selectedBrokerAccount.displayName : '' }}.</div>
            </div>
            {% if exposure %}
                <div class="row g-4 align-items-center">
                    <div class="col-lg-5 d-flex justify-content-center">
                        <canvas id="portfolio-exposure-chart" class="portfolio-exposure-chart" width="320" height="320" aria-label="Portfolio exposure by stock" role="img"></canvas>
                    </div>
                    <div class="col-lg-7">
                        <div class="portfolio-exposure-legend-scroll">
                            <div id="portfolio-exposure-legend" class="portfolio-exposure-legend">
                                {% for item in exposure %}
                                    {% set companyLabel = item.companyName ?: item.symbol %}
                                    <div class="portfolio-exposure-item">
                                        <span class="portfolio-exposure-swatch" data-exposure-swatch="{{ loop.index0 }}"></span>
                                        <div class="min-w-0">
                                            <div class="fw-semibold text-truncate">{{ item.symbol }}</div>
                                            <div class="small text-secondary text-truncate" title="{{ companyLabel }}">
                                                {{ companyLabel|length > 10 ? companyLabel|slice(0, 10) ~ '...' : companyLabel }}
                                            </div>
                                        </div>
                                        <div>
                                            <div class="fw-semibold">{{ item.percent|trim_number }}%</div>
                                            <div class="small text-secondary">{{ item.marketValue|money_symbol(item.currency) }}</div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="border rounded-3 p-4 text-secondary">
                    Exposure is unavailable until current market values are available.
                </div>
            {% endif %}
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            {% if positions %}
                <div class="d-flex flex-column flex-md-row justify-content-between gap-2 mb-3 text-secondary small">
                    <div>
                        Showing {{ pagination.firstItem }}-{{ pagination.lastItem }} of {{ pagination.totalItems }} positions
                    </div>
                    <div>
                        {{ pagination.perPage }} per page
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover-pop align-middle">
                        <thead>
                            <tr>
                                <th>Symbol</th>
                                <th class="text-end">Total shares</th>
                                <th class="text-end">Average cost</th>
                                <th class="text-end">Current price</th>
                                <th class="text-end">Market value</th>
                                <th class="text-end">Realized P/L</th>
                                <th class="text-end">Unrealized P/L</th>
                                <th class="text-end">Total P/L</th>
                                <th class="text-end">Total P/L %</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for position in positions %}
                                {% set rowId = 'portfolio-breakdown-' ~ loop.index %}
                                <tr>
                                    <td>
                                        <button class="btn btn-sm btn-outline-secondary me-2" type="button" data-bs-toggle="collapse" data-bs-target="#{{ rowId }}" aria-expanded="false" aria-controls="{{ rowId }}">+</button>
                                        <a class="fw-semibold text-decoration-none" href="{{ path('app_stock_show', { symbol: position.symbol }) }}"><span class="fw-semibold">{{ position.symbol }}</span></a>

                                    </td>
                                    <td class="text-end">{{ position.totalShares|trim_number }}</td>
                                    <td class="text-end">{{ position.averageCost|money_symbol(position.currency) }}</td>
                                    <td class="text-end">{{ position.marketDataAvailable ? position.currentPrice|money_symbol(position.currency) : 'Unavailable' }}</td>
                                    <td class="text-end">{{ position.marketDataAvailable ? position.marketValue|money_symbol(position.currency) : 'Unavailable' }}</td>
                                    <td class="text-end {{ position.realizedGain starts with '-' ? 'text-negative' : 'text-positive' }}">
                                        {{ position.realizedGain|money_symbol(position.currency) }}
                                    </td>
                                    <td class="text-end {{ position.marketDataAvailable and position.unrealizedGain starts with '-' ? 'text-negative' : 'text-positive' }}">
                                        {{ position.marketDataAvailable ? position.unrealizedGain|money_symbol(position.currency) : 'Unavailable' }}
                                    </td>
                                    <td class="text-end {{ position.marketDataAvailable and position.totalGain starts with '-' ? 'text-negative' : 'text-positive' }}">
                                        {{ position.marketDataAvailable ? position.totalGain|money_symbol(position.currency) : 'Unavailable' }}
                                    </td>
                                    <td class="text-end {{ position.marketDataAvailable and position.totalGainPercent starts with '-' ? 'text-negative' : 'text-positive' }}">
                                        {{ position.marketDataAvailable ? position.totalGainPercent|trim_number ~ '%' : 'Unavailable' }}
                                    </td>
                                </tr>
                                <tr class="collapse" id="{{ rowId }}">
                                    <td colspan="11" class="bg-light">
                                        <div class="p-3">
                                            <div class="fw-semibold mb-2">{{ position.symbol }} breakdown by broker account</div>
                                            <div class="table-responsive">
                                                <table class="table table-sm table-hover-pop mb-0">
                                                    <thead>
                                                        <tr>
                                                            <th>Broker account</th>
                                                            <th class="text-end">Shares</th>
                                                            <th class="text-end">Average cost</th>
                                                            <th class="text-end">Current price</th>
                                                            <th class="text-end">Market value</th>
                                                            <th class="text-end">Realized P/L</th>
                                                            <th class="text-end">Unrealized P/L</th>
                                                            <th class="text-end">Total P/L</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        {% for breakdown in position.breakdown %}
                                                            <tr>
                                                                <td>{{ breakdown.brokerAccount }}</td>
                                                                <td class="text-end">{{ breakdown.shares|trim_number }}</td>
                                                                <td class="text-end">{{ breakdown.averageCost|money_symbol(position.currency) }}</td>
                                                                <td class="text-end">{{ breakdown.marketDataAvailable ? breakdown.currentPrice|money_symbol(position.currency) : 'Unavailable' }}</td>
                                                                <td class="text-end">{{ breakdown.marketDataAvailable ? breakdown.marketValue|money_symbol(position.currency) : 'Unavailable' }}</td>
                                                                <td class="text-end {{ breakdown.realizedGain starts with '-' ? 'text-negative' : 'text-positive' }}">
                                                                    {{ breakdown.realizedGain|money_symbol(position.currency) }}
                                                                </td>
                                                                <td class="text-end {{ breakdown.marketDataAvailable and breakdown.unrealizedGain starts with '-' ? 'text-negative' : 'text-positive' }}">
                                                                    {{ breakdown.marketDataAvailable ? breakdown.unrealizedGain|money_symbol(position.currency) : 'Unavailable' }}
                                                                </td>
                                                                <td class="text-end {{ breakdown.marketDataAvailable and breakdown.totalGain starts with '-' ? 'text-negative' : 'text-positive' }}">
                                                                    {{ breakdown.marketDataAvailable ? breakdown.totalGain|money_symbol(position.currency) : 'Unavailable' }}
                                                                </td>
                                                            </tr>
                                                        {% endfor %}
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {% if pagination.totalPages > 1 %}
                    {% set startPage = pagination.currentPage - 2 %}
                    {% set endPage = pagination.currentPage + 2 %}
                    {% if startPage < 1 %}
                        {% set startPage = 1 %}
                    {% endif %}
                    {% if endPage > pagination.totalPages %}
                        {% set endPage = pagination.totalPages %}
                    {% endif %}

                    <nav class="mt-4" aria-label="Portfolio pagination">
                        <ul class="pagination justify-content-end mb-0">
                            <li class="page-item {{ pagination.currentPage == 1 ? 'disabled' }}">
                                <a class="page-link" href="{{ path('app_portfolio', pagination.queryParams|merge({ page: pagination.currentPage - 1 })) }}" aria-label="Previous">
                                    Previous
                                </a>
                            </li>

                            {% if startPage > 1 %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('app_portfolio', pagination.queryParams|merge({ page: 1 })) }}">1</a>
                                </li>
                                {% if startPage > 2 %}
                                    <li class="page-item disabled"><span class="page-link">...</span></li>
                                {% endif %}
                            {% endif %}

                            {% for page in startPage..endPage %}
                                <li class="page-item {{ page == pagination.currentPage ? 'active' }}">
                                    <a class="page-link" href="{{ path('app_portfolio', pagination.queryParams|merge({ page: page })) }}">{{ page }}</a>
                                </li>
                            {% endfor %}

                            {% if endPage < pagination.totalPages %}
                                {% if endPage < pagination.totalPages - 1 %}
                                    <li class="page-item disabled"><span class="page-link">...</span></li>
                                {% endif %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('app_portfolio', pagination.queryParams|merge({ page: pagination.totalPages })) }}">{{ pagination.totalPages }}</a>
                                </li>
                            {% endif %}

                            <li class="page-item {{ pagination.currentPage == pagination.totalPages ? 'disabled' }}">
                                <a class="page-link" href="{{ path('app_portfolio', pagination.queryParams|merge({ page: pagination.currentPage + 1 })) }}" aria-label="Next">
                                    Next
                                </a>
                            </li>
                        </ul>
                    </nav>
                {% endif %}
            {% else %}
                <div class="border rounded-3 p-4 text-secondary">
                    No open positions yet. Upload transactions to build your portfolio.
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const canvas = document.getElementById('portfolio-exposure-chart');
            const exposure = {{ exposure|json_encode|raw }};
            const numberFormat = '{{ app.user.numberFormat|default('comma_dot') }}';

            if (!canvas || !window.Chart || exposure.length === 0) {
                return;
            }

            const colors = [
                '#2563eb', '#16a34a', '#dc2626', '#f59e0b', '#7c3aed',
                '#0891b2', '#db2777', '#4f46e5', '#65a30d', '#ea580c',
                '#0f766e', '#be123c'
            ];
            const total = exposure.reduce((carry, item) => carry + Number(item.marketValueFloat || 0), 0);
            const moneySymbol = (currency) => ({
                EUR: '€',
                GBP: '£',
                JPY: '¥',
                USD: '$'
            }[String(currency || '').toUpperCase()] || `${String(currency || '').toUpperCase()} `);
            const formatNumber = (value) => {
                const rounded = Number(value || 0).toFixed(4).replace(/0+$/, '').replace(/\.$/, '');
                const [whole, decimal = ''] = rounded.split('.');
                const thousands = numberFormat === 'dot_comma' ? '.' : ',';
                const decimalSeparator = numberFormat === 'dot_comma' ? ',' : '.';
                const grouped = whole.replace(/\B(?=(\d{3})+(?!\d))/g, thousands);
                const paddedDecimal = decimal.length === 1 ? `${decimal}0` : decimal;

                return paddedDecimal === '' ? grouped : `${grouped}${decimalSeparator}${paddedDecimal}`;
            };
            const formatMoney = (value, currency) => `${moneySymbol(currency)}${formatNumber(value)}`;

            if (total <= 0) {
                return;
            }

            new Chart(canvas, {
                type: 'doughnut',
                data: {
                    labels: exposure.map((item) => item.symbol),
                    datasets: [{
                        data: exposure.map((item) => Number(item.marketValueFloat || 0)),
                        backgroundColor: exposure.map((item, index) => colors[index % colors.length]),
                        borderColor: '#ffffff',
                        borderWidth: 3,
                        hoverBorderColor: '#111827',
                        hoverBorderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '58%',
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                title: (items) => {
                                    const item = exposure[items[0].dataIndex];

                                    return item.companyName ? `${item.symbol} - ${item.companyName}` : item.symbol;
                                },
                                label: (context) => {
                                    const item = exposure[context.dataIndex];

                                    return `${item.percent}% exposure: ${formatMoney(item.marketValueFloat, item.currency)}`;
                                }
                            }
                        }
                    }
                }
            });

            document.querySelectorAll('[data-exposure-swatch]').forEach((swatch) => {
                const index = Number(swatch.dataset.exposureSwatch || 0);
                swatch.style.backgroundColor = colors[index % colors.length];
            });
        });
    </script>
{% endblock %}
