{% for transaction in transactions %}
    {% set entries = entriesByTransactionId[transaction.id]|default([]) %}
    {% set defaultType = transaction.type == 'SELL' ? 'SELL_REASON' : 'BUY_REASON' %}
    <div class="modal fade" id="transactionJournal{{ transaction.id }}" tabindex="-1" aria-labelledby="transactionJournal{{ transaction.id }}Label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <div class="small text-secondary mb-1">{{ transaction.type }} {{ transaction.quantity|trim_number }} {{ transaction.symbol }} @ {{ transaction.price|money_symbol(transaction.currency) }}</div>
                        <h2 class="modal-title fs-5" id="transactionJournal{{ transaction.id }}Label">Transaction Journal</h2>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex flex-wrap gap-2 mb-4" role="group" aria-label="Journal actions">
                        <button type="button" class="btn btn-sm btn-outline-success" data-journal-action="add" data-journal-transaction="{{ transaction.id }}">Add note</button>
                        {% if entries %}
                            <button type="button" class="btn btn-sm btn-dark" data-journal-action="view" data-journal-tone="dark" data-journal-transaction="{{ transaction.id }}">View notes</button>
                        {% endif %}
                    </div>

                    <div data-journal-panel="add" data-journal-transaction="{{ transaction.id }}" hidden>
                        <h3 class="h6 mb-3">Add transaction note</h3>
                        <form method="post" action="{{ path('app_journal_transaction_save', { transactionId: transaction.id }) }}" data-transaction-journal-form data-transaction-id="{{ transaction.id }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('transaction_journal_' ~ transaction.id) }}">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label" for="add-entry-type-{{ transaction.id }}">Entry type</label>
                                    <select class="form-select" id="add-entry-type-{{ transaction.id }}" name="entry_type" required>
                                        {% for value, label in entryTypes %}<option value="{{ value }}" {{ value == defaultType ? 'selected' }}>{{ label }}</option>{% endfor %}
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="add-entry-date-{{ transaction.id }}">Entry date</label>
                                    <input class="form-control" id="add-entry-date-{{ transaction.id }}" type="date" name="entry_date" value="{{ transaction.date }}" required>
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="add-title-{{ transaction.id }}">Title <span class="text-secondary">(optional)</span></label>
                                    <input class="form-control" id="add-title-{{ transaction.id }}" name="title" maxlength="180">
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="add-content-{{ transaction.id }}">Note</label>
                                    <textarea class="form-control" id="add-content-{{ transaction.id }}" name="content" rows="5" required></textarea>
                                </div>
                            </div>
                            <button class="btn btn-dark mt-3" type="submit">Save note</button>
                        </form>
                    </div>

                    {% if entries %}
                        <div data-journal-panel="view" data-journal-transaction="{{ transaction.id }}" hidden>
                            <div class="vstack gap-3">
                                {% for entry in entries %}
                                    <article class="border rounded-3 p-3">
                                        <div class="d-flex flex-column flex-sm-row align-items-sm-start justify-content-between gap-2 mb-2">
                                            <div class="d-flex flex-wrap align-items-center gap-2">
                                                <span class="badge badge-journal-general">{{ entry.entryTypeLabel }}</span>
                                                <span class="small text-secondary">{{ entry.entryDate|date('F j, Y') }}</span>
                                            </div>
                                            <button type="button" class="btn btn-sm btn-outline-primary" data-journal-action="edit-{{ entry.id }}" data-journal-transaction="{{ transaction.id }}">Edit note</button>
                                        </div>
                                        {% if entry.title %}<h3 class="h6 mb-2">{{ entry.title }}</h3>{% endif %}
                                        <p class="small mb-0" style="white-space: pre-line;">{{ entry.content }}</p>
                                    </article>
                                {% endfor %}
                            </div>
                        </div>

                        {% for entry in entries %}
                            <div data-journal-panel="edit-{{ entry.id }}" data-journal-transaction="{{ transaction.id }}" hidden>
                                <h3 class="h6 mb-3">Edit transaction note</h3>
                                <form method="post" action="{{ path('app_journal_transaction_save', { transactionId: transaction.id }) }}" data-transaction-journal-form data-transaction-id="{{ transaction.id }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('transaction_journal_' ~ transaction.id) }}">
                                    <input type="hidden" name="entry_id" value="{{ entry.id }}">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label" for="edit-entry-type-{{ entry.id }}">Entry type</label>
                                            <select class="form-select" id="edit-entry-type-{{ entry.id }}" name="entry_type" required>
                                                {% for value, label in entryTypes %}<option value="{{ value }}" {{ value == entry.entryType ? 'selected' }}>{{ label }}</option>{% endfor %}
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label" for="edit-entry-date-{{ entry.id }}">Entry date</label>
                                            <input class="form-control" id="edit-entry-date-{{ entry.id }}" type="date" name="entry_date" value="{{ entry.entryDate|date('Y-m-d') }}" required>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label" for="edit-title-{{ entry.id }}">Title <span class="text-secondary">(optional)</span></label>
                                            <input class="form-control" id="edit-title-{{ entry.id }}" name="title" value="{{ entry.title }}" maxlength="180">
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label" for="edit-content-{{ entry.id }}">Note</label>
                                            <textarea class="form-control" id="edit-content-{{ entry.id }}" name="content" rows="5" required>{{ entry.content }}</textarea>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2 mt-3">
                                        <button class="btn btn-dark" type="submit">Save changes</button>
                                        <button type="button" class="btn btn-outline-secondary" data-journal-action="view" data-journal-transaction="{{ transaction.id }}">Back to notes</button>
                                    </div>
                                </form>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endfor %}
