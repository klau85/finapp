{% extends 'base.html.twig' %}

{% block title %}{{ stock.symbol }} Journal | NorthLens{% endblock %}

{% block main %}
    <div class="d-flex flex-column flex-md-row align-items-md-start justify-content-between gap-3 mb-4">
        <div>
            <div class="page-kicker">Stock journal</div>
            <h1 class="h2 mb-1">{{ stock.symbol }} Journal</h1>
            <p class="text-secondary mb-0">{{ stock.companyName ?: stock.symbol }}</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-dark" href="{{ path('app_journal_new', { stock: stock.symbol }) }}">+ Add Journal Entry</a>
            <a class="btn btn-outline-secondary" href="{{ path('app_stock_show', { symbol: stock.symbol }) }}">Back to stock</a>
        </div>
    </div>

    {% if entries %}
        {% include 'journal/_timeline.html.twig' with { entries: entries } only %}
    {% else %}
        <div class="card"><div class="card-body p-5 text-center"><h2 class="h5 mb-3">No journal entries for this stock yet.</h2><a class="btn btn-dark" href="{{ path('app_journal_new', { stock: stock.symbol }) }}">+ Add Journal Entry</a></div></div>
    {% endif %}
{% endblock %}
