<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}FinApp{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%231f2937'/%3E%3Cpath d='M15 42h34M18 36l8-8 7 6 13-15' stroke='%2322c55e' stroke-width='5' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E">
        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
            <style>
                :root {
                    --landing-soft: #f5f7f6;
                    --landing-green: #167c4c;
                    --landing-ink: #151a1e;
                    --landing-green-light: #e5f2e9;
                    --landing-red: #c83d42;
                    --landing-red-light: #fbdcdc;
                    --app-bg: var(--landing-soft);
                    --app-border: #e5e7eb;
                    --app-muted: #6b7280;
                }

                body {
                    background: #f4f6f8;
                    color: var(--landing-ink);
                    font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
                    letter-spacing: 0;
                }

                body.app-admin {
                    background: var(--app-bg);
                }

                .app-shell {
                    min-height: 100vh;
                }

                .app-sidebar {
                    background: #fff;
                    border-right: 1px solid var(--app-border);
                    color: var(--landing-ink);
                    flex: 0 0 260px;
                    height: 100vh;
                    overflow-y: auto;
                    position: sticky;
                    top: 0;
                    width: 260px;
                }

                .app-sidebar .nav-link {
                    border-radius: 8px;
                    color: var(--landing-ink);
                    font-weight: 500;
                    padding: .7rem .85rem;
                }

                .app-sidebar .nav-link:hover,
                .app-sidebar .nav-link.active {
                    background: var(--landing-green-light);
                    color: var(--landing-green);
                }

                .app-brand,
                .app-sidebar-user {
                    color: var(--landing-ink);
                }

                .app-mobile-nav {
                    border-bottom: 1px solid var(--app-border);
                }

                .app-content {
                    margin: 0 auto;
                    max-width: 1200px;
                    padding: 28px 20px 48px;
                    width: 100%;
                }

                .card {
                    border: 1px solid var(--app-border);
                    border-radius: 12px;
                    box-shadow: 0 10px 30px rgba(15, 23, 42, .06);
                }

                .portfolio-value-card {
                    background: var(--landing-green);
                    color: #fff;
                }

                .portfolio-value-card .metric-label {
                    color: rgba(255, 255, 255, .8) !important;
                }

                .portfolio-value-card .h3,
                .portfolio-value-card .h5 {
                    color: #fff;
                }

                .app-admin .btn:not(.btn-danger):not(.btn-outline-danger):not(.btn-close) {
                    background-color: var(--landing-green-light);
                    border-color: transparent;
                    color: var(--landing-green);
                }

                .app-admin .btn:not(.btn-danger):not(.btn-outline-danger):not(.btn-close):hover,
                .app-admin .btn:not(.btn-danger):not(.btn-outline-danger):not(.btn-close):focus,
                .app-admin .btn:not(.btn-danger):not(.btn-outline-danger):not(.btn-close).active,
                .app-admin .btn:not(.btn-danger):not(.btn-outline-danger):not(.btn-close):active {
                    background-color: var(--landing-green);
                    border-color: transparent;
                    color: #fff;
                }

                .app-admin .btn.app-header-action:not(.btn-danger):not(.btn-outline-danger):not(.btn-close) {
                    background-color: #fff;
                    border-color: transparent;
                    color: var(--landing-ink);
                }

                .app-admin .btn.app-header-action:not(.btn-danger):not(.btn-outline-danger):not(.btn-close):hover,
                .app-admin .btn.app-header-action:not(.btn-danger):not(.btn-outline-danger):not(.btn-close):focus,
                .app-admin .btn.app-header-action:not(.btn-danger):not(.btn-outline-danger):not(.btn-close):active {
                    background-color: var(--landing-ink);
                    border-color: transparent;
                    color: var(--landing-soft);
                }

                .app-admin .btn-danger,
                .app-admin .btn-outline-danger {
                    background-color: var(--landing-red-light);
                    border-color: transparent;
                    color: var(--landing-red);
                }

                .app-admin .btn-danger:hover,
                .app-admin .btn-danger:focus,
                .app-admin .btn-danger.active,
                .app-admin .btn-danger:active,
                .app-admin .btn-outline-danger:hover,
                .app-admin .btn-outline-danger:focus,
                .app-admin .btn-outline-danger.active,
                .app-admin .btn-outline-danger:active {
                    background-color: var(--landing-red);
                    border-color: transparent;
                    color: #fff;
                }

                .app-admin .btn:disabled,
                .app-admin .btn.disabled {
                    border-color: transparent;
                }

                .metric-card {
                    min-height: 132px;
                }

                .summary-metric-card {
                    min-height: 0;
                }

                .metric-label[data-bs-toggle="tooltip"] {
                    cursor: help;
                    text-decoration: underline dotted;
                    text-underline-offset: 3px;
                }

                .text-positive {
                    --bs-table-color-state: #15803d;
                    color: #15803d;
                }

                .text-negative {
                    --bs-table-color-state: #dc2626;
                    color: #dc2626;
                }

                .badge-buy {
                    background: #dcfce7;
                    color: #166534;
                }

                .badge-sell {
                    background: #fee2e2;
                    color: #991b1b;
                }

                .auth-card {
                    max-width: 460px;
                    width: 100%;
                }

                .page-kicker {
                    color: var(--app-muted);
                    font-size: .92rem;
                }

                .table-hover-pop tbody tr {
                    transition: background-color .15s ease, box-shadow .15s ease, transform .15s ease;
                }

                .table-hover-pop tbody tr:hover {
                    background: #ffffff;
                    box-shadow: 0 8px 22px rgba(15, 23, 42, .12);
                    position: relative;
                    transform: translateY(-1px);
                    z-index: 1;
                }

                .journal-timeline {
                    margin-left: .5rem;
                    padding-left: 1.75rem;
                    position: relative;
                }

                .journal-timeline::before {
                    background: #d1d5db;
                    bottom: 0;
                    content: "";
                    left: .35rem;
                    position: absolute;
                    top: 0;
                    width: 2px;
                }

                .journal-timeline-item {
                    position: relative;
                }

                .journal-timeline-dot {
                    background: #fff;
                    border: 3px solid #2563eb;
                    border-radius: 50%;
                    height: .85rem;
                    left: -1.82rem;
                    position: absolute;
                    top: 1.35rem;
                    width: .85rem;
                }

                .badge-journal-positive { background: #dcfce7; color: #166534; }
                .badge-journal-negative { background: #fee2e2; color: #991b1b; }
                .badge-journal-risk { background: #fef3c7; color: #92400e; }
                .badge-journal-info { background: #dbeafe; color: #1e40af; }
                .badge-journal-general { background: #e5e7eb; color: #374151; }

                @media (max-width: 991.98px) {
                    .app-content {
                        padding-top: 20px;
                    }
                }
            </style>
        {% endblock %}

        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
        {% endblock %}
    </head>
    <body class="{{ app.user ? 'app-admin' : 'app-public' }}">
        {% set navItems = [
            { label: 'Dashboard', route: 'app_dashboard' },
            { label: 'Portfolio', route: 'app_portfolio' },
            { label: 'Transactions', route: 'app_transactions' },
            { label: 'Journal', route: 'app_journal', routePrefix: 'app_journal' },
            { label: 'Upload', route: 'app_transaction_upload' },
            { label: 'Broker Accounts', route: 'app_broker_accounts' },
            { label: 'Settings', route: 'app_settings' }
        ] %}

        {% block body %}
            {% if app.user %}
                <nav class="navbar navbar-expand-lg bg-white app-mobile-nav d-lg-none">
                    <div class="container-fluid">
                        <a class="navbar-brand fw-semibold" href="{{ path('app_dashboard') }}">FinApp</a>
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNav" aria-controls="mobileNav" aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="collapse navbar-collapse" id="mobileNav">
                            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                                {% for item in navItems %}
                                    <li class="nav-item">
                                        <a class="nav-link {{ app.current_route == item.route or (item.routePrefix is defined and app.current_route starts with item.routePrefix) ? 'active fw-semibold' }}" href="{{ path(item.route) }}">{{ item.label }}</a>
                                    </li>
                                {% endfor %}
                            </ul>
                            <a class="btn btn-outline-secondary btn-sm" href="{{ path('app_logout') }}">Logout</a>
                        </div>
                    </div>
                </nav>
                <div class="app-shell d-lg-flex">
                    <aside class="app-sidebar d-none d-lg-flex flex-column p-4">
                        <a class="app-brand text-decoration-none fs-4 fw-semibold mb-4" href="{{ path('app_dashboard') }}">FinApp</a>
                        <nav class="nav nav-pills flex-column gap-1">
                            {% for item in navItems %}
                                <a class="nav-link {{ app.current_route == item.route or (item.routePrefix is defined and app.current_route starts with item.routePrefix) ? 'active' }}" href="{{ path(item.route) }}">{{ item.label }}</a>
                            {% endfor %}
                        </nav>
                        <div class="mt-auto pt-4">
                            <div class="app-sidebar-user small mb-2">{{ app.user.userIdentifier }}</div>
                            <a class="btn btn-sm w-100" href="{{ path('app_logout') }}">Logout</a>
                        </div>
                    </aside>
                    <main class="flex-grow-1">
                        <div class="app-content">
                            {% include '_flash.html.twig' %}
                            {% block main %}{% endblock %}
                        </div>
                    </main>
                </div>
            {% else %}
                <main class="min-vh-100 d-flex align-items-center justify-content-center p-3">
                    {% include '_flash.html.twig' %}
                    {% block auth %}{% endblock %}
                </main>
            {% endif %}
        {% endblock %}
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((element) => {
                    new bootstrap.Tooltip(element);
                });
            });
        </script>
    </body>
</html>
