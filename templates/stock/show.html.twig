{% extends 'base.html.twig' %}

{% block title %}{{ symbol }} | FinApp{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .stock-chart-stage {
            position: relative;
        }

        .chart-transaction-overlay {
            background: #ffffff;
            border: 1px solid var(--app-border);
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(15, 23, 42, .18);
            left: 0;
            max-height: 300px;
            overflow-y: auto;
            padding: .75rem;
            position: absolute;
            top: 0;
            width: min(320px, calc(100% - 16px));
            z-index: 20;
        }

        .chart-event-detail {
            color: #374151;
            font-size: .875rem;
            line-height: 1.35;
        }

        .chart-transaction-close {
            align-items: center;
            background: transparent;
            border: 0;
            color: #374151;
            display: inline-flex;
            font-size: 1.4rem;
            height: 28px;
            justify-content: center;
            line-height: 1;
            padding: 0;
            width: 28px;
        }

        .chart-transaction-close:hover {
            color: #111827;
        }
    </style>
{% endblock %}

{% block main %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
        <div>
            <div class="page-kicker">Stock page</div>
            <h1 class="h2 mb-0">{{ symbol }}</h1>
            <div class="text-secondary">{{ companyName ?: symbol }}</div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <div class="btn-group" role="group" aria-label="Chart timeframe">
                <a class="btn btn-sm {{ timeframe == 'daily' ? 'btn-dark' : 'btn-outline-secondary' }}" href="{{ path('app_stock_show', { symbol: symbol, timeframe: 'daily' }) }}">1D</a>
                <a class="btn btn-sm {{ timeframe == 'weekly' ? 'btn-dark' : 'btn-outline-secondary' }}" href="{{ path('app_stock_show', { symbol: symbol, timeframe: 'weekly' }) }}">1W</a>
            </div>
            <button class="btn btn-dark" type="button" data-bs-toggle="modal" data-bs-target="#stockJournalModal">Journal</button>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            {% if chartUnavailable %}
                <div class="border rounded-3 p-4 text-secondary">Chart data is unavailable at this moment.</div>
            {% endif %}
            <div id="stock-chart-stage" class="stock-chart-stage {{ chartUnavailable ? 'd-none' : '' }}">
                <div id="stock-chart" style="height: 460px;"></div>
                <div id="chart-transaction-overlay" class="chart-transaction-overlay" hidden></div>
            </div>
            {% if not chartUnavailable and markers %}
                <div hidden aria-hidden="true">
                    {% for marker in markers %}
                        <template id="chart-transaction-template-{{ loop.index0 }}">
                            <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                                <div class="d-flex align-items-center gap-2 pt-1">
                                    <span class="small fw-semibold">{{ marker.time }}</span>
                                    <span class="badge {{ marker.type == 'BUY' ? 'badge-buy' : (marker.type == 'SELL' ? 'badge-sell' : 'text-bg-secondary') }}">{{ marker.text }}</span>
                                </div>
                                <button type="button" class="chart-transaction-close flex-shrink-0" data-chart-transaction-close aria-label="Close transaction details">&times;</button>
                            </div>
                                {% for detail in marker.details %}
                                    {% set transactionId = marker.transactionIds[loop.index0] %}
                                    <div
                                        class="{{ not loop.first ? 'mt-3 pt-3 border-top' }}"
                                        {% if not loop.first %}data-extra-transaction hidden{% endif %}
                                    >
                                        <div class="d-flex align-items-center justify-content-between gap-2">
                                            <div class="chart-event-detail">{{ detail }}</div>
                                            <button type="button" class="btn btn-sm btn-dark flex-shrink-0" data-bs-toggle="modal" data-bs-target="#transactionJournal{{ transactionId }}">Journal</button>
                                        </div>
                                    </div>
                                {% endfor %}
                                {% if marker.details|length > 1 %}
                                    <div class="mt-3">
                                        <button type="button" class="btn btn-sm btn-link px-0 text-decoration-none" data-transactions-toggle aria-expanded="false">
                                            <span data-more-label>More</span>
                                            <span data-less-label hidden>Less</span>
                                        </button>
                                    </div>
                                {% endif %}
                        </template>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

    {% include 'journal/_transaction_modals.html.twig' with {
        transactions: transactions,
        entriesByTransactionId: journalEntriesByTransactionId,
        entryTypes: journalEntryTypes
    } only %}
    {% include 'journal/_stock_modal.html.twig' with {
        stock: stock,
        entries: stockJournalEntries,
        entryTypes: journalEntryTypes
    } only %}

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <div class="text-secondary mb-2">Total Shares</div>
                    <div class="h3 mb-0">{{ position ? position.totalShares|trim_number : '0' }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <div class="text-secondary mb-2">Market Value</div>
                    <div class="h3 mb-0">
                        {{ position and position.marketDataAvailable ? position.marketValue|money_symbol(position.currency) : 'Unavailable' }}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <div class="text-secondary mb-2">Realized P/L</div>
                    <div class="h3 mb-0 {{ position ? position.realizedGain|metric_class }}">
                        {{ position ? position.realizedGain|signed_money(position.currency) : '$0' }}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <div class="text-secondary mb-2">Unrealized P/L</div>
                    <div class="h3 mb-0 {{ position and position.marketDataAvailable ? position.unrealizedGain|metric_class }}">
                        {{ position and position.marketDataAvailable ? position.unrealizedGain|signed_money(position.currency) : 'Unavailable' }}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5 mb-3">Position summary</h2>
                    {% if position %}
                        <dl class="row mb-0">
                            <dt class="col-6 text-secondary">Average cost</dt>
                            <dd class="col-6 text-end">{{ position.averageCost|money_symbol(position.currency) }}</dd>
                            <dt class="col-6 text-secondary">Current price</dt>
                            <dd class="col-6 text-end">{{ position.marketDataAvailable ? position.currentPrice|money_symbol(position.currency) : 'Unavailable' }}</dd>
                            <dt class="col-6 text-secondary">Total P/L</dt>
                            <dd class="col-6 text-end {{ position.marketDataAvailable ? position.totalGain|metric_class }}">
                                {{ position.marketDataAvailable ? position.totalGain|signed_money(position.currency) : 'Unavailable' }}
                            </dd>
                            <dt class="col-6 text-secondary">Total P/L %</dt>
                            <dd class="col-6 text-end {{ position.marketDataAvailable ? position.totalGainPercent|metric_class }}">
                                {{ position.marketDataAvailable ? position.totalGainPercent|signed_percent : 'Unavailable' }}
                            </dd>
                        </dl>
                    {% else %}
                        <p class="text-secondary mb-0">No open position. Raw transactions are still shown below.</p>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5 mb-3">Broker account breakdown</h2>
                    {% if position and position.breakdown %}
                        <div class="table-responsive">
                            <table class="table table-sm table-hover-pop mb-0">
                                <thead>
                                    <tr>
                                        <th>Broker account</th>
                                        <th class="text-end">Shares</th>
                                        <th class="text-end">Realized P/L</th>
                                        <th class="text-end">Unrealized P/L</th>
                                        <th class="text-end">Total P/L</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for breakdown in position.breakdown %}
                                        <tr>
                                            <td>{{ breakdown.brokerAccount }}</td>
                                            <td class="text-end">{{ breakdown.shares|trim_number }}</td>
                                            <td class="text-end {{ breakdown.realizedGain|metric_class }}">{{ breakdown.realizedGain|signed_money(position.currency) }}</td>
                                            <td class="text-end {{ breakdown.marketDataAvailable ? breakdown.unrealizedGain|metric_class }}">
                                                {{ breakdown.marketDataAvailable ? breakdown.unrealizedGain|signed_money(position.currency) : 'Unavailable' }}
                                            </td>
                                            <td class="text-end {{ breakdown.marketDataAvailable ? breakdown.totalGain|metric_class }}">
                                                {{ breakdown.marketDataAvailable ? breakdown.totalGain|signed_money(position.currency) : 'Unavailable' }}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <p class="text-secondary mb-0">No open broker-account lots for this stock.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h2 class="h5 mb-3">Transaction history</h2>
            <div class="table-responsive">
                <table class="table table-hover-pop align-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Broker Account</th>
                            <th>Type</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Price</th>
                            <th class="text-end">Fees</th>
                            <th>Currency</th>
                            <th class="text-end">Broker amount</th>
                            <th class="text-end">Total amount</th>
                            <th class="text-end">Journal</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for transaction in transactions %}
                            <tr>
                                <td>{{ transaction.date }}</td>
                                <td>{{ transaction.brokerAccount }}</td>
                                <td>
                                    {% if transaction.type == 'BUY' %}
                                        <span class="badge badge-buy">BUY</span>
                                    {% elseif transaction.type == 'SELL' %}
                                        <span class="badge badge-sell">SELL</span>
                                    {% else %}
                                        <span class="badge text-bg-secondary">{{ transaction.type|replace({'_': ' '}) }}</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">{{ transaction.quantity|trim_number }}</td>
                                <td class="text-end">{{ transaction.price|money_symbol(transaction.currency) }}</td>
                                <td class="text-end">{{ transaction.fees|money_symbol(transaction.currency) }}</td>
                                <td>{{ transaction.currency }}</td>
                                <td class="text-end">
                                    {% if transaction.brokerAmount is not null and transaction.brokerCurrency is not null %}
                                        {{ transaction.brokerAmount|money_symbol(transaction.brokerCurrency) }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td class="text-end">{{ transaction.totalAmount|money_symbol(transaction.currency) }}</td>
                                {% set journalEntry = latestJournalEntryByTransactionId[transaction.id]|default(null) %}
                                <td class="text-end">
                                    {% if journalEntry %}
                                        <a class="btn btn-sm btn-outline-primary" href="{{ path('app_journal_edit', { id: journalEntry.id }) }}">Edit</a>
                                    {% else %}
                                        <a class="btn btn-sm btn-outline-success" href="{{ path('app_journal_new', { transaction: transaction.id }) }}" title="Add journal entry" aria-label="Add journal entry for this transaction"><span class="fw-semibold" aria-hidden="true">+</span><span class="visually-hidden"> Journal</span></a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/lightweight-charts/dist/lightweight-charts.standalone.production.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const container = document.getElementById('stock-chart');
            const chartStage = document.getElementById('stock-chart-stage');
            const transactionOverlay = document.getElementById('chart-transaction-overlay');
            const candles = {{ candles|json_encode|raw }};
            const markers = {{ markers|json_encode|raw }};
            document.querySelectorAll('[data-journal-action]').forEach((action) => {
                action.addEventListener('click', () => {
                    const transactionId = action.dataset.journalTransaction;
                    document.querySelectorAll(`[data-journal-panel][data-journal-transaction="${transactionId}"]`).forEach((panel) => {
                        panel.hidden = panel.dataset.journalPanel !== action.dataset.journalAction;
                    });
                    document.querySelectorAll(`[data-journal-action][data-journal-transaction="${transactionId}"]`).forEach((button) => {
                        const actionName = button.dataset.journalAction;
                        const active = button === action;
                        button.classList.remove('btn-dark', 'btn-primary', 'btn-success', 'btn-outline-primary', 'btn-outline-secondary', 'btn-outline-success');
                        button.classList.add(actionName.startsWith('edit-')
                            ? (active ? 'btn-primary' : 'btn-outline-primary')
                            : (actionName === 'add'
                                ? (active ? 'btn-success' : 'btn-outline-success')
                                : (button.dataset.journalTone === 'dark' || active ? 'btn-dark' : 'btn-outline-secondary')));
                    });
                });
            });
            transactionOverlay?.addEventListener('click', (event) => {
                const close = event.target.closest('[data-chart-transaction-close]');
                if (close) {
                    transactionOverlay.hidden = true;
                    transactionOverlay.replaceChildren();

                    return;
                }

                const toggle = event.target.closest('[data-transactions-toggle]');
                if (toggle) {
                    const expanded = toggle.getAttribute('aria-expanded') === 'true';
                    transactionOverlay.querySelectorAll('[data-extra-transaction]').forEach((transaction) => {
                        transaction.hidden = expanded;
                    });
                    toggle.setAttribute('aria-expanded', String(!expanded));
                    toggle.querySelector('[data-more-label]').hidden = !expanded;
                    toggle.querySelector('[data-less-label]').hidden = expanded;
                }
            });

            const markerDataById = new Map();
            const chartMarkers = markers.map(({ time, position, color, shape, text }, index) => {
                const id = `transaction-marker-${index}`;
                markerDataById.set(id, { index, time });

                return { id, time, position, color, shape, text };
            });

            if (!container || !window.LightweightCharts || candles.length === 0) {
                return;
            }

            const chart = LightweightCharts.createChart(container, {
                autoSize: true,
                layout: {
                    background: { type: 'solid', color: '#ffffff' },
                    textColor: '#111827'
                },
                grid: {
                    vertLines: { color: '#eef2f7' },
                    horzLines: { color: '#eef2f7' }
                },
                rightPriceScale: {
                    borderColor: '#e5e7eb'
                },
                timeScale: {
                    borderColor: '#e5e7eb',
                    timeVisible: false,
                    secondsVisible: false
                }
            });

            const series = chart.addSeries(LightweightCharts.CandlestickSeries, {
                upColor: '#16a34a',
                downColor: '#dc2626',
                borderVisible: false,
                wickUpColor: '#16a34a',
                wickDownColor: '#dc2626'
            });

            series.setData(candles);

            if (typeof LightweightCharts.createSeriesMarkers === 'function') {
                LightweightCharts.createSeriesMarkers(series, chartMarkers);
            } else if (typeof series.setMarkers === 'function') {
                series.setMarkers(chartMarkers);
            }

            const rightPaddingBars = 30;
            const showTransactionCard = (marker, point) => {
                const template = document.getElementById(`chart-transaction-template-${marker.index}`);
                if (!template || !transactionOverlay || !chartStage || !point) {
                    return;
                }

                transactionOverlay.replaceChildren(template.content.cloneNode(true));
                transactionOverlay.hidden = false;

                const margin = 8;
                const left = Math.min(
                    Math.max(margin, point.x - (transactionOverlay.offsetWidth / 2)),
                    chartStage.clientWidth - transactionOverlay.offsetWidth - margin
                );
                const top = Math.min(
                    point.y + 20,
                    chartStage.clientHeight - transactionOverlay.offsetHeight - margin
                );
                transactionOverlay.style.left = `${Math.max(margin, left)}px`;
                transactionOverlay.style.top = `${Math.max(margin, top)}px`;
            };

            chart.subscribeCrosshairMove((param) => {
                const marker = markerDataById.get(String(param.hoveredObjectId ?? ''));
                container.style.cursor = marker ? 'pointer' : '';
            });

            chart.subscribeClick((param) => {
                const marker = markerDataById.get(String(param.hoveredObjectId ?? ''));
                if (marker) {
                    showTransactionCard(marker, param.point);
                }
            });

            chart.timeScale().subscribeVisibleLogicalRangeChange(() => {
                if (transactionOverlay && !transactionOverlay.hidden) {
                    transactionOverlay.hidden = true;
                    transactionOverlay.replaceChildren();
                }
            });

            const latestCandleTime = candles[candles.length - 1].time;
            const visibleFromDate = new Date(`${latestCandleTime}T00:00:00Z`);
            visibleFromDate.setUTCMonth(visibleFromDate.getUTCMonth() - 16);
            chart.timeScale().setVisibleRange({
                from: visibleFromDate.toISOString().slice(0, 10),
                to: latestCandleTime
            });

            const visibleLogicalRange = chart.timeScale().getVisibleLogicalRange();
            if (visibleLogicalRange !== null) {
                chart.timeScale().setVisibleLogicalRange({
                    from: visibleLogicalRange.from,
                    to: visibleLogicalRange.to + rightPaddingBars
                });
            }
        });
    </script>
{% endblock %}
