{% extends 'base.html.twig' %}

{% block title %}Preview Import | FinApp{% endblock %}

{% block main %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
        <div>
            <div class="page-kicker">Preview</div>
            <h1 class="h2 mb-0">Review CSV rows</h1>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('app_transaction_upload') }}">Upload another file</a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="text-secondary small">Broker account</div>
                    <div class="fw-semibold">{{ brokerAccount.displayName }}</div>
                </div>
                <div class="col-md-4">
                    <div class="text-secondary small">File</div>
                    <div class="fw-semibold">{{ originalFileName }}</div>
                </div>
                <div class="col-md-4">
                    <div class="text-secondary small">Status</div>
                    {% if hasErrors and canImport %}
                        <span class="badge text-bg-warning">Partial import</span>
                    {% elseif hasErrors %}
                        <span class="badge text-bg-danger">Validation errors</span>
                    {% else %}
                        <span class="badge text-bg-success">Ready to import</span>
                    {% endif %}
                </div>
            </div>
            {% if hasErrors %}
                <div class="alert {{ canImport ? 'alert-warning' : 'alert-danger' }} mt-3 mb-0">
                    {% if canImport %}
                        {{ validRowCount }} valid row{{ validRowCount == 1 ? '' : 's' }} will be imported.
                        {{ invalidRowCount }} invalid row{{ invalidRowCount == 1 ? '' : 's' }} will be skipped.
                    {% else %}
                        No valid rows were found. Fix the CSV and upload it again.
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover-pop align-middle">
                    <thead>
                        <tr>
                            <th>Row</th>
                            <th>Date</th>
                            <th>Symbol</th>
                            <th>Type</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Price</th>
                            <th>Currency</th>
                            <th class="text-end">Fees</th>
                            <th>Validation</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in rows %}
                            {% set data = row.data %}
                            <tr class="{{ row.valid ? '' : 'table-danger' }}">
                                <td>{{ row.rowNumber }}</td>
                                <td>{{ data.date ?? '-' }}</td>
                                <td class="fw-semibold">{{ data.symbol ?? '-' }}</td>
                                <td>
                                    {% if (data.type ?? '') == 'BUY' %}
                                        <span class="badge badge-buy">BUY</span>
                                    {% elseif (data.type ?? '') == 'SELL' %}
                                        <span class="badge badge-sell">SELL</span>
                                    {% else %}
                                        {{ data.type ?? '-' }}
                                    {% endif %}
                                </td>
                                <td class="text-end">{{ data.quantity is defined ? data.quantity|trim_number : '-' }}</td>
                                <td class="text-end">{{ data.price is defined ? data.price|trim_number : '-' }}</td>
                                <td>{{ data.currency ?? '-' }}</td>
                                <td class="text-end">{{ data.fees is defined ? data.fees|trim_number : '-' }}</td>
                                <td>
                                    {% if row.valid %}
                                        <span class="text-positive">Valid</span>
                                    {% else %}
                                        <ul class="mb-0 ps-3">
                                            {% for error in row.errors %}
                                                <li>{{ error }}</li>
                                            {% endfor %}
                                        </ul>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-end mt-3">
                <form action="{{ path('app_transaction_upload_confirm') }}" method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('transaction_upload_confirm') }}">
                    <button class="btn btn-dark" type="submit" {{ canImport ? '' : 'disabled' }}>
                        {{ hasErrors ? 'Import valid rows' : 'Confirm import' }}
                    </button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
