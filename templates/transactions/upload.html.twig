{% extends 'base.html.twig' %}

{% block title %}Upload Transactions | FinApp{% endblock %}

{% block main %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
        <div>
            <div class="page-kicker">Transactions</div>
            <h1 class="h2 mb-0">Upload Transactions CSV</h1>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('app_broker_accounts') }}">Manage broker accounts</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card">
                <div class="card-body">
                    <h2 class="h5 mb-3">CSV import</h2>
                    <div class="alert alert-info">
                        For now, only US stocks can be imported.
                    </div>

                    {% if brokerAccounts is empty %}
                        <div class="alert alert-warning mb-0">
                            Create a broker account before uploading transactions.
                        </div>
                    {% else %}
                        <form action="{{ path('app_transaction_upload_preview') }}" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="_token" value="{{ csrf_token('transaction_upload') }}">

                            <div class="mb-3">
                                <label for="brokerAccountId" class="form-label">Broker account</label>
                                <select id="brokerAccountId" name="brokerAccountId" class="form-select" required>
                                    <option value="">Select account</option>
                                    {% for account in brokerAccounts %}
                                        <option value="{{ account.id }}">{{ account.displayName }} · {{ account.brokerTypeLabel }} · {{ account.currency }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="csv_file" class="form-label">CSV file</label>
                                <input id="csv_file" name="csv_file" type="file" class="form-control" accept=".csv,text/csv" required>
                            </div>

                            <button class="btn btn-dark w-100" type="submit">Preview import</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card">
                <div class="card-body">
                    <h2 class="h5 mb-3">Custom CSV format</h2>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>date</th>
                                    <th>symbol</th>
                                    <th>type</th>
                                    <th>quantity</th>
                                    <th>price</th>
                                    <th>currency</th>
                                    <th>fees</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>2026-02-12</td>
                                    <td>NVDA</td>
                                    <td><span class="badge badge-buy">BUY</span></td>
                                    <td>100</td>
                                    <td>142.50</td>
                                    <td>USD</td>
                                    <td>1.00</td>
                                </tr>
                                <tr>
                                    <td>2026-03-13</td>
                                    <td>CRWD</td>
                                    <td><span class="badge badge-sell">SELL</span></td>
                                    <td>50</td>
                                    <td>520.00</td>
                                    <td>USD</td>
                                    <td>1.00</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <p class="text-secondary mb-4">Broker is not included in the CSV. Transactions are imported into the selected broker account only.</p>

                    <h2 class="h5 mb-3">XTB CSV format</h2>
                    <p class="text-secondary">For XTB broker accounts, upload the CSV downloaded from XTB. The importer reads these columns and ignores the rest. Only tickers ending in .US are imported.</p>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Ticker</th>
                                    <th>Time</th>
                                    <th>Comment</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Stock purchase</td>
                                    <td>NVDA.US</td>
                                    <td>2026-02-12 9:15:00</td>
                                    <td>OPEN BUY 1/1.18 @ 43.37</td>
                                    <td>-43.37</td>
                                </tr>
                                <tr>
                                    <td>Stock sell</td>
                                    <td>MSFT.US</td>
                                    <td>2026-03-13 14:30:00</td>
                                    <td>CLOSE BUY 0.14/0.34 @ 645.64</td>
                                    <td>90.39</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <p class="text-secondary mb-0">XTB imports save the Comment price as USD price/currency. The absolute Amount value is saved separately in the selected broker account currency. Fees are set to 0. Rows with non-US tickers are marked invalid and skipped.</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
