{% extends 'base.html.twig' %}

{% block title %}Upload Transactions | FinApp{% endblock %}

{% block main %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
        <div>
            <div class="page-kicker">Transactions</div>
            <h1 class="h2 mb-0">Upload Transactions CSV</h1>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('app_broker_accounts') }}">Manage broker accounts</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card">
                <div class="card-body">
                    <h2 class="h5 mb-3">CSV import</h2>
                    <div class="alert alert-info">
                        Custom and Revolut imports support USD rows for now. XTB imports support US and selected EU suffixes.
                    </div>

                    {% if brokerAccounts is empty %}
                        <div class="alert alert-warning mb-0">
                            Create a broker account before uploading transactions.
                        </div>
                    {% else %}
                        <form action="{{ path('app_transaction_upload_preview') }}" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="_token" value="{{ csrf_token('transaction_upload') }}">

                            <div class="mb-3">
                                <label for="brokerAccountId" class="form-label">Broker account</label>
                                <select id="brokerAccountId" name="brokerAccountId" class="form-select" required>
                                    <option value="">Select account</option>
                                    {% for account in brokerAccounts %}
                                        <option value="{{ account.id }}" data-broker-type="{{ account.brokerType }}">{{ account.displayName }} · {{ account.brokerTypeLabel }} · {{ account.currency }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="csv_file" class="form-label">CSV file</label>
                                <input id="csv_file" name="csv_file" type="file" class="form-control" accept=".csv,text/csv" required>
                            </div>

                            <button class="btn btn-dark w-100" type="submit">Preview import</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card">
                <div class="card-body">
                    <div data-import-format="custom">
                        <h2 class="h5 mb-3">Custom CSV format</h2>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>date</th>
                                        <th>symbol</th>
                                        <th>type</th>
                                        <th>quantity</th>
                                        <th>price</th>
                                        <th>currency</th>
                                        <th>fees</th>
                                        <th>amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>2026-02-12</td>
                                        <td>NVDA</td>
                                        <td><span class="badge badge-buy">BUY</span></td>
                                        <td>100</td>
                                        <td>202.50</td>
                                        <td>USD</td>
                                        <td>1.00</td>
                                        <td>17842.88</td>
                                    </tr>
                                    <tr>
                                        <td>2026-03-13</td>
                                        <td>CRWD</td>
                                        <td><span class="badge badge-sell">SELL</span></td>
                                        <td>50</td>
                                        <td>520.00</td>
                                        <td>USD</td>
                                        <td>0.00</td>
                                        <td>22909.38</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <p class="text-secondary mb-0">Transactions are imported into the selected broker account only.<br>
                            Custom CSV import supports USD only; rows with another currency are marked invalid and skipped.<br>
                            The optional amount column is saved as the broker amount in the selected broker account currency. <br>
                            In the example above the stock currency is USD and the price is in USD.
                            The selected broker account currency is EUR, so the amount is in EUR.</p>
                    </div>

                    <div data-import-format="xtb" hidden>
                        <h2 class="h5 mb-3">XTB CSV format</h2>
                        <p class="text-secondary">For XTB broker accounts, upload the CSV downloaded from XTB.</p>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Type</th>
                                        <th>Ticker</th>
                                        <th>Time</th>
                                        <th>Comment</th>
                                        <th>Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Stock purchase</td>
                                        <td>NVDA.US</td>
                                        <td>2026-02-12 9:15:00</td>
                                        <td>OPEN BUY 1/1.18 @ 43.37</td>
                                        <td>-43.37</td>
                                    </tr>
                                    <tr>
                                        <td>Stock sell</td>
                                        <td>MSFT.US</td>
                                        <td>2026-03-13 14:30:00</td>
                                        <td>CLOSE BUY 0.14/0.34 @ 645.64</td>
                                        <td>90.39</td>
                                    </tr>
                                    <tr>
                                        <td>Stock purchase</td>
                                        <td>VOW.DE</td>
                                        <td>2026-04-15 10:20:00</td>
                                        <td>OPEN BUY 1 @ 118.40</td>
                                        <td>-118.40</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <p class="text-secondary mb-0">XTB imports save the Comment price as USD for .US or no-suffix tickers, and EUR for .DE, .FR, .PA, and .AS tickers. <br>
                            The absolute Amount value is saved separately in the selected broker account currency.<br>
                            Rows with unsupported ticker suffixes are marked invalid and skipped.
                        </p>
                    </div>

                    <div data-import-format="revolut" hidden>
                        <h2 class="h5 mb-3">Revolut CSV format</h2>
                        <p class="text-secondary">For Revolut broker accounts, upload the investments CSV downloaded from the Revolut app.</p>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Ticker</th>
                                        <th>Type</th>
                                        <th>Quantity</th>
                                        <th>Price per share</th>
                                        <th>Currency</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>2021-10-14T10:28:43.503438Z</td>
                                        <td>NVDA</td>
                                        <td>BUY - MARKET</td>
                                        <td>2</td>
                                        <td>USD 50.56</td>
                                        <td>USD</td>
                                    </tr>
                                    <tr>
                                        <td>2021-11-18T15:40:10.100000Z</td>
                                        <td>AAPL</td>
                                        <td>SELL - MARKET</td>
                                        <td>1</td>
                                        <td>USD 151.20</td>
                                        <td>USD</td>
                                    </tr>
                                    <tr>
                                        <td>2024-06-17T07:44:52.740377Z</td>
                                        <td>SPCE</td>
                                        <td>STOCK SPLIT</td>
                                        <td>-5.70525065</td>
                                        <td></td>
                                        <td>USD</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <p class="text-secondary mb-0">Revolut imports support BUY - MARKET, SELL - MARKET, and STOCK SPLIT rows.<br>
                            Stock split rows adjust open FIFO lots and preserve the current cost basis.<br>
                            Rows with empty tickers, non-USD prices, or non-USD currency are marked invalid and skipped.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const brokerSelect = document.getElementById('brokerAccountId');
            const sections = document.querySelectorAll('[data-import-format]');

            if (!brokerSelect || sections.length === 0) {
                return;
            }

            const updateImportFormat = () => {
                const selectedOption = brokerSelect.options[brokerSelect.selectedIndex];
                const brokerType = ['xtb', 'revolut'].includes(selectedOption?.dataset.brokerType)
                    ? selectedOption.dataset.brokerType
                    : 'custom';

                sections.forEach((section) => {
                    section.hidden = section.dataset.importFormat !== brokerType;
                });
            };

            brokerSelect.addEventListener('change', updateImportFormat);
            updateImportFormat();
        });
    </script>
{% endblock %}
